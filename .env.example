# Copy this to .env and fill in your values.
# On Railway/Render, set these in the dashboard environment variables tab.

# ── Admin credentials ──────────────────────────
# Change these before deploying to production!
ADMIN_USERNAME=samkell
ADMIN_PASSWORD=your-strong-password-here

# ── Server ────────────────────────────────────
PORT=8080

# ── Gin mode ──────────────────────────────────
# Set to "release" in production (disables debug output)
GIN_MODE=release
